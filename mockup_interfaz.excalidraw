    {
      "id": "OKbn8l5FIn3GkReKoyogc",
      "type": "text",
      "x": 2137.86602637219,
      "y": 4181.177388637897,
      "width": 588.6897591543275,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
